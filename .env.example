# Azure OpenAI Configuration (Recommended)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.1
# For TTS with gpt-audio (uses Chat Completions API with audio modality)
AZURE_OPENAI_AUDIO_DEPLOYMENT=gpt-audio
# API version (must be 2025-01-01-preview or later for audio modalities support)
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Standard OpenAI Configuration (Alternative)
# If not using Azure, uncomment and use this instead:
#OPENAI_API_KEY=your_openai_api_key_here

# Replicate Configuration (for Image Generation and STT)
REPLICATE_API_TOKEN=your_replicate_token_here
